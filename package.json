{
  "name": "solo-ceo",
  "productName": "一人CEO",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "main": "electron-dist/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:prepare": "mkdir -p electron-dist && cp electron/main.cjs electron-dist/main.cjs",
    "electron:build-all": "npm run build && npm run electron:prepare",
    "electron:pack": "npm run electron:build-all && npx electron-builder --mac --arm64",
    "release": "npm run electron:build-all && npx electron-builder --mac --arm64 --publish always",
    "electron:test": "npm run electron:build-all && npx electron ."
  },
  "build": {
    "appId": "com.soloceo.app",
    "productName": "一人CEO",
    "copyright": "Copyright © 2025",
    "publish": {
      "provider": "github"
    },
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "一人CEO",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "electron-dist/**",
      "dist/**"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.21",
    "@vitejs/plugin-react": "^5.0.4",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "sql.js": "^1.14.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
